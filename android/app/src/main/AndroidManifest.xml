<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BLE dual-role mesh (DESIGN.md §5.2): advertise + scan + connect.
         neverForLocation: we only match a fixed service UUID and never derive
         physical location from scan results, so we don't need (and don't
         want) to also request ACCESS_FINE_LOCATION. Without this flag,
         Android silently withholds scan results unless the app also holds
         location permission and Location is enabled on the device. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- QR-code friending (DESIGN.md §6.2) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Internet relay flush (DESIGN.md §9), best-effort only -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Keeps mesh sync alive while backgrounded -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Requests exemption from Doze/App Standby so mesh sync survives while
         backgrounded, matching bitchat's pattern. User-facing system dialog;
         declining just means less reliable backgrounded sync, not a hard
         failure. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.CruiseMesh"
        android:supportsRtl="true">

        <!-- singleTop: a message-notification tap while the app is already
             open must land in the running activity's onNewIntent (warm-start
             deep link into that chat) instead of relaunching it. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.CruiseMesh">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".mesh.MeshService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />
    </application>
</manifest>
