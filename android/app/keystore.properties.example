# Copy to keystore.properties (gitignored) and fill in with your upload
# keystore's real values to produce a Play-signable release build:
#
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 \
#     -validity 10000 -alias cruisemesh-upload
#
# storeFile is resolved relative to android/app/. CI can instead set the
# CRUISEMESH_RELEASE_STORE_FILE / _STORE_PASSWORD / _KEY_ALIAS / _KEY_PASSWORD
# env vars and skip this file entirely.
storeFile=upload-keystore.jks
storePassword=
keyAlias=cruisemesh-upload
keyPassword=
